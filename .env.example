# ============================================
# TELEGRAM SHOP BOT - CẤU HÌNH
# ============================================
# Copy file này thành .env và điền thông tin

# === BẮT BUỘC ===
# Token từ @BotFather
BOT_TOKEN=your_telegram_bot_token

# ID Telegram của admin (phân cách bằng dấu phẩy nếu nhiều admin)
# Lấy ID tại @userinfobot
ADMIN_IDS=123456789,987654321

# Độ dài tối đa thực dụng cho text nút inline Telegram (mặc định: 64)
BOT_INLINE_BUTTON_TEXT_MAX=64

# === TELEGRAM API STABILITY ===
# Tăng nhẹ timeout/retry khi server production mạng chập chờn.
BOT_TELEGRAM_CONNECT_TIMEOUT=30
BOT_TELEGRAM_READ_TIMEOUT=45
BOT_TELEGRAM_WRITE_TIMEOUT=45
BOT_TELEGRAM_POOL_TIMEOUT=30
BOT_TELEGRAM_API_RETRY_ATTEMPTS=3
BOT_TELEGRAM_API_RETRY_DELAY=0.8

# === SEPAY - NẠP TIỀN TỰ ĐỘNG ===
# Lấy token tại: sepay.vn → Cài đặt → API
SEPAY_API_TOKEN=your_sepay_api_token
# Giới hạn transaction mỗi lần poll (mặc định nội bộ: 200 nếu để trống)
SEPAY_LIMIT=200
# Fallback limit khi SEPAY_LIMIT không đặt (nên giữ 200)
SEPAY_DEFAULT_LIMIT=200

# Thông tin ngân hàng nhận tiền
SEPAY_BANK_NAME=MBBank
SEPAY_ACCOUNT_NUMBER=0123456789
SEPAY_ACCOUNT_NAME=NGUYEN VAN A

# === SUPABASE ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_STORAGE_BUCKET=admin-uploads

# === TÙY CHỌN - MOMO (nếu dùng) ===
MOMO_PHONE=0123456789
MOMO_NAME=NGUYEN VAN A

# === THANH TOÁN SẢN PHẨM ===
# direct: luôn tạo VietQR khi mua hàng
# hybrid: chỉ tạo VietQR khi thiếu balance
# balance: phải nạp balance trước khi mua
PAYMENT_MODE=hybrid
