# ============================================
# TELEGRAM SHOP BOT - CẤU HÌNH
# ============================================
# Copy file này thành .env và điền thông tin

# === BẮT BUỘC ===
# Token từ @BotFather
BOT_TOKEN=your_telegram_bot_token

# ID Telegram của admin (phân cách bằng dấu phẩy nếu nhiều admin)
# Lấy ID tại @userinfobot
ADMIN_IDS=123456789,987654321

# Độ dài tối đa thực dụng cho text nút inline Telegram (mặc định: 64)
BOT_INLINE_BUTTON_TEXT_MAX=64

# === TELEGRAM API STABILITY ===
# Tăng nhẹ timeout/retry khi server production mạng chập chờn.
BOT_TELEGRAM_CONNECT_TIMEOUT=30
BOT_TELEGRAM_READ_TIMEOUT=45
BOT_TELEGRAM_WRITE_TIMEOUT=45
BOT_TELEGRAM_POOL_TIMEOUT=30
BOT_TELEGRAM_API_RETRY_ATTEMPTS=3
BOT_TELEGRAM_API_RETRY_DELAY=0.8
# Giúp click inline button phản hồi nhanh hơn: callback answer thường sẽ chạy nền.
BOT_CALLBACK_ANSWER_BACKGROUND=true
BOT_CALLBACK_ANSWER_TIMEOUT=1.2

# Payment relay notify dùng aiohttp riêng để gọi api.telegram.org.
# Nếu VPS/Windows có CA nội bộ, trỏ file PEM vào đây thay vì tắt verify.
PAYMENT_RELAY_TIMEOUT_SECONDS=20
PAYMENT_RELAY_CA_BUNDLE=
# true: nếu cert verify fail, retry 1 lần với ssl=False chỉ cho relay notify.
PAYMENT_RELAY_SSL_AUTO_FALLBACK_NO_VERIFY=true
# Chỉ bật tạm khi production bị TLS interception/self-signed chain và chưa có CA bundle nội bộ.
PAYMENT_RELAY_SSL_NO_VERIFY=false

# === SEPAY - NẠP TIỀN TỰ ĐỘNG ===
# Lấy token tại: sepay.vn → Cài đặt → API
SEPAY_API_TOKEN=your_sepay_api_token
# Giới hạn transaction mỗi lần poll (mặc định nội bộ: 200 nếu để trống)
SEPAY_LIMIT=200
# Fallback limit khi SEPAY_LIMIT không đặt (nên giữ 200)
SEPAY_DEFAULT_LIMIT=200

# Thông tin ngân hàng nhận tiền
SEPAY_BANK_NAME=MBBank
SEPAY_ACCOUNT_NUMBER=0123456789
SEPAY_ACCOUNT_NAME=NGUYEN VAN A

# === SUPABASE ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_STORAGE_BUCKET=admin-uploads
SUPABASE_NETWORK_RETRY_ATTEMPTS=2
SUPABASE_NETWORK_RETRY_DELAY=0.35

# === TÙY CHỌN - MOMO (nếu dùng) ===
MOMO_PHONE=0123456789
MOMO_NAME=NGUYEN VAN A

# === THANH TOÁN SẢN PHẨM ===
# direct: external-only. Tiếng Việt -> VietQR, English -> Binance.
# hybrid: chọn Wallet hoặc external. Tiếng Việt -> Wallet/VietQR, English -> Wallet/Binance.
# balance: phải nạp balance trước khi mua
PAYMENT_MODE=hybrid

# === BINANCE DIRECT PAYMENT ===
# Ưu tiên cấu hình trong Dashboard Settings. Các biến dưới đây là fallback khi DB chưa có setting.
BINANCE_DIRECT_ENABLED=false
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_PAY_ID=
BINANCE_DIRECT_COIN=USDT
BINANCE_DIRECT_NETWORK=BSC
BINANCE_DIRECT_ADDRESS=
BINANCE_DIRECT_ADDRESS_TAG=
BINANCE_DIRECT_RATE=25000

# Binance signed requests rất nhạy với lệch giờ. Code sẽ tự sync /api/v3/time;
# vẫn nên bật Windows Time/NTP trên production. recvWindow chỉ xử lý request chậm,
# không thay thế việc đồng bộ giờ khi máy local nhanh hơn server Binance.
BINANCE_RECV_WINDOW_MS=10000
