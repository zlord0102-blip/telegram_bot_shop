# Public Supabase URL (same project as bot/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-side key used by API routes only (do not expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional fallback bank settings when DB settings are empty
SEPAY_BANK_NAME=MBBank
SEPAY_ACCOUNT_NUMBER=0123456789
SEPAY_ACCOUNT_NAME=NGUYEN VAN A
